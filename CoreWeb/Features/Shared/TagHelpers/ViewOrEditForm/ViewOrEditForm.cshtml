@using CoreBackend.Resources
@using CoreWeb.Features.Shared
@model ViewOrEditForm
@inject ISharedTranslationsGetter SharedTranslationsGetter
<form method="post"
      action="@Model.Action"
      data-view-or-edit-form-target="form"
      asp-antiforgery="true"
      >
    @Model.ChildContent
    
    <div class="row">
        <div class="col text-end d-flex justify-content-end gap-2">
            
            @{
                var sharedTranslations = SharedTranslationsGetter.GetSharedTranslations();
            }

            <button type="button"
                    data-view-or-edit-form-target="edit"
                    data-action="@CoreWebStimulusControllers.ViewOrEditForm#edit"
                    class="btn btn-outline-primary"
                    >
                @sharedTranslations.Edit
            </button>
            <button type="button"
                    data-view-or-edit-form-target="cancel"
                    data-action="@CoreWebStimulusControllers.ViewOrEditForm#cancel"
                    class="btn btn-outline-primary"
                    style="display: none"
                    >
                @sharedTranslations.Cancel
            </button>
            <button type="submit"
                    data-view-or-edit-form-target="save"
                    class="btn btn-primary"
                    style="display: none"
                    >
                @sharedTranslations.Save
            </button>
        </div>
    </div>
</form>