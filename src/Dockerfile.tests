# Stage 1: Build
FROM mcr.microsoft.com/dotnet/sdk:10.0-alpine@sha256:9b4b31da5246f575086b1901e9871b189ae2a80eb42fe9234e9d000b51febd4b AS build
WORKDIR /app

# Install Node.js and npm
RUN apk add --no-cache nodejs npm

# Copy only project files first for better layer caching
COPY CoreBackend/*.csproj ./CoreBackend/
COPY CoreBackend.Postgres/*.csproj ./CoreBackend.Postgres/
COPY CoreBackend.Register.Castle/*.csproj ./CoreBackend.Register.Castle/
COPY CoreBackend.Register.ServiceProvider/*.csproj ./CoreBackend.Register.ServiceProvider/
COPY Core/*.csproj ./Core/
COPY CoreWeb/*.csproj ./CoreWeb/
COPY Web/*.csproj ./Web/
COPY SharedAssemblyInfo.props .
RUN dotnet restore Web/Web.csproj

# Install Node packages
WORKDIR /app/CoreWeb
COPY CoreWeb/package*.json ./
RUN npm ci

WORKDIR /app/Web
COPY Web/package*.json ./
RUN npm ci

# Copy the remaining source code
WORKDIR /app
COPY CoreBackend/. ./CoreBackend/
COPY CoreBackend.Postgres/. ./CoreBackend.Postgres/
COPY CoreBackend.Register.Castle/. ./CoreBackend.Register.Castle/
COPY CoreBackend.Register.ServiceProvider/. ./CoreBackend.Register.ServiceProvider/
COPY Core/. ./Core/
COPY CoreWeb/. ./CoreWeb/
COPY Web/. ./Web/
RUN mkdir -p ./DatabaseScripts/ChangeScripts
COPY DatabaseScripts/ChangeScripts/. ./DatabaseScripts/ChangeScripts/

# Build front-end assets
WORKDIR /app/Web
RUN npx tsc --noEmit && node esbuild.config.js
WORKDIR /app

# ******************************* Make sure the above is the same as for Dockerfile to be able to benefit from cached layers *******************************

# Copy only csproj files first
COPY MrWatchdog.sln .
COPY CoreBackend.TestsShared/*.csproj CoreBackend.TestsShared/
COPY Core.TestsShared/*.csproj Core.TestsShared/
COPY Core.Tests/*.csproj Core.Tests/
COPY Web.E2E.Tests/*.csproj Web.E2E.Tests/
COPY Web.Tests/*.csproj Web.Tests/
COPY ToolsApp/*.csproj ToolsApp/

# Restore all projects (creates a cached layer)
RUN dotnet restore

# Copy test projects files
COPY CoreBackend.TestsShared/. ./CoreBackend.TestsShared/
COPY Core.TestsShared/. ./Core.TestsShared/
COPY Core.Tests/. ./Core.Tests/
COPY Web.E2E.Tests/. ./Web.E2E.Tests/
COPY Web.Tests/. ./Web.Tests/
COPY ToolsApp/. ./ToolsApp/

RUN dotnet build

# ---- Runtime container: runs the tests ----
FROM mcr.microsoft.com/dotnet/sdk:10.0-alpine@sha256:9b4b31da5246f575086b1901e9871b189ae2a80eb42fe9234e9d000b51febd4b

# Install Alpine-native Chromium and Node.js (these are compiled for Apline's musl)
RUN apk add --no-cache chromium nss freetype harfbuzz ca-certificates ttf-freefont nodejs xvfb dbus mesa-gl

WORKDIR /app

# Tell Playwright to use system Node
ENV PLAYWRIGHT_NODEJS_PATH=/usr/bin/node
# This tells the .NET driver where the Alpine-native browser is
ENV PlaywrightScraper__BrowserExecutablePath=/usr/bin/chromium-browser

COPY --from=build /app .

# Copy NuGet packages cache
COPY --from=build /root/.nuget/packages /root/.nuget/packages

# Start Xvfb in the background to support headed Chrome browser and then run tests
ENTRYPOINT ["/bin/sh", "-c", "Xvfb :99 -screen 0 1920x1080x24 & export DISPLAY=:99 && dotnet test --no-restore --no-build"]
