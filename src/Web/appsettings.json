{
  "DatabaseConnectionStringName": "Database",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Rebus": "Debug",
        "Rebus.Bus": "Debug"
      }
    }
  },
  "AllowedHosts": "*",
  "DetailedErrors": true,
  "Rebus": {
    "Transport": "RabbitMQ", // Options: RabbitMQ, PostgreSql, InMemory
    "MaxDeliveryAttempts": 5,
    "DefaultNumberOfWorkers": 4,
    "NumberOfWorkersByQueue": {
      "Main": 10,
      "Scraping": 4,
      "Email": 4
    }
  },
  "Jwt": {
    "ExpireMinutes": 15
  },
  "ReCaptcha": {
    "Version": "v3"
  },
  "RateLimiting": {
    "GlobalRequestsPerSecondPerUserPermitLimit": 100,
    "GlobalRequestsPerSecondPerUserQueueLimit": 0,

    "LogErrorRequestsPerSecondPerUserPermitLimit": 4,
    "LogErrorRequestsPerSecondPerUserQueueLimit": 0
  },
  "SmtpClientDirectlyToRecipientMailServerEmailSender": {
    "MailServerRateLimitingCoolDownPeriodInMinutes": 120
  },
  "KickOffDueScrapersScrapingHostedService": {
    "DelayBetweenKickOffsInSeconds": 10
  },
  "WatchdogScrapedResults": {
    "RefreshHashes": false
  }
}
